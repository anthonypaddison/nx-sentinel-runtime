{
    "root": true,
    "env": {
        "browser": true,
        "node": true,
        "es2023": true
    },
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
    },
    "extends": ["eslint:recommended"],
    "rules": {
        "no-unused-vars": ["warn", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }],
        "curly": ["warn", "all"],
        "eqeqeq": ["warn", "always"],
        "no-empty": "warn",
        "no-undef": "error"
    }
}
